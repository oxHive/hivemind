{
  "name": "@oxhive/opencode-hivemind",
  "version": "0.7.0",
  "description": "HiveMind persistent memory plugin for OpenCode. Auto-registers MCP server and provides memory skills.",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "mcp",
    "memory",
    "ai",
    "agent"
  ],
  "homepage": "https://github.com/oxhive/hivemind#readme",
  "bugs": {
    "url": "https://github.com/oxhive/hivemind/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxHive/hivemind.git",
    "directory": "plugins/opencode"
  },
  "license": "AGPL-3.0-only",
  "author": "oxhive",
  "type": "commonjs",
  "main": "hivemind.js",
  "files": [
    "hivemind.js",
    "skills/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build --target=bun hivemind.ts --outfile=hivemind.js && bun run scripts/resolve-skills.ts",
