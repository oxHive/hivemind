meta {
  name: Save Sync Settings
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/v1/settings/sync
  body: json
  auth: none
}

body:json {
  {
    "enabled": true,
    "remote_url": "http://remote-hivemind:3456",
    "api_key": "your-api-key",
    "interval_seconds": 300,
    "sync_on_store": true,
    "sync_on_startup": true
  }
}

docs {
  NOTE: In v1, sync settings are read from config.toml — this endpoint always
  returns saved: false. Edit ~/.config/hivemind/config.toml and restart hivemind.
}
